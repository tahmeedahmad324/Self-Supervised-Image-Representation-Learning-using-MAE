oencoder\nclass MaskedAutoencoder(nn.Module):\n    def __init__(self, img_size, patch_size, in_chans,\n                 encoder_embed_dim, encoder_depth, encoder_num_heads,\n                 decoder_embed_dim, decoder_depth, decoder_num_heads,\n                 mask_ratio):\n        super().__init__()\n        \n        self.patch_size = patch_size\n        self.mask_ratio = mask_ratio\n        num_patches = (img_size // patch_size) ** 2\n        \n        # Encoder\n        self.encoder = ViTEncoder(\n            img_size=img_size,\n            patch_size=patch_size,\n            in_chans=in_chans,\n            embed_dim=encoder_embed_dim,\n            depth=encoder_depth,\n            num_heads=encoder_num_heads\n        )\n        \n        # Decoder\n        self.decoder = ViTDecoder(\n            num_patches=num_patches,\n            patch_size=patch_size,\n            in_chans=in_chans,\n            embed_dim=decoder_embed_dim,\n            depth=decoder_depth,\n            num_heads=decoder_num_heads,\n            encoder_embed_dim=encoder_embed_dim\n        )\n    \n    def forward(self, imgs):\n        patches = patchify(imgs, self.patch_size)\n        patches_masked, mask, ids_restore, ids_keep = random_masking(patches, self.mask_ratio)\n        latent = self.encoder(patches_masked, pos_indices=ids_keep)\n        pred = self.decoder(latent, ids_restore)\n        \n        return pred, mask, patches\n\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-10T17:16:11.325436Z","iopub.execute_input":"2026-03-10T17:16:11.325679Z","iopub.status.idle":"2026-03-10T17:16:11.336172Z","shell.execute_reply.started":"2026-03-10T17:16:11.325660Z","shell.execute_reply":"2026-03-10T17:16:11.335665Z"}},"outputs":[],"execution_count":60},{"cell_type":"code","source":"# Cell 14: Initialize Model\nmodel = MaskedAutoencoder(\n    img_size=IMG_SIZE,\n    patch_size=PATCH_SIZE,\n    in_chans=3,  # Add this!\n    encoder_embed_dim=ENC_DIM,\n    encoder_depth=ENC