,"execution_count":56},{"cell_type":"code","source":"class ViTEncoder(nn.Module):\n    def __init__(self, img_size, patch_size, in_chans, embed_dim, depth, num_heads):\n        super().__init__()\n        num_patches = (img_size // patch_size) ** 2\n        self.patch_embed = nn.Linear(patch_size * patch_size * in_chans, embed_dim)\n        self.pos_embed = nn.Parameter(torch.zeros(1, num_patches, embed_dim))\n        \n        # Transformer blocks\n        self.blocks = nn.ModuleList([\n            TransformerBlock(embed_dim, num_heads) for _ in range(depth)\n        ])\n        \n        self.norm = nn.LayerNorm(embed_dim)\n    \n    def forward(self, x, pos_indices=None):\n        batch, seq_len, embed_dim = x.shape\n        x = self.patch_embed(x)\n\n        if pos_indices is not None:\n            pos_embed = torch.gather(\n                self.pos_embed.expand(batch, -1, -1),\n                dim=1,\n                index=pos_indices.unsqueeze(-1).expand(-1, -1, x.shape[-1])\n            )\n            x = x + pos_embed\n        else:\n            x = x + self.pos_embed[:, :N, :]\n            \n        for block in self.blocks:\n            x = block(x)\n        x = self.norm(x)\n        return x","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-10T17:16:11.284980Z","iopub.execute_input":"2026-03-10T17:16:11.285197Z","iopub.status.idle":"2026-03-10T17:16:11.294144Z","shell.execute_reply.started":"2026-03-10T17:16:11.285162Z","shell.execute_reply":"2026-03-10T17:16:11.293593Z"}},"outputs":[],"execution_count":57},{"cell_type":"code","source":"class ViTDecoder(nn.Module):\n    def __init__(self, num_patches, patch_size, in_chans, embed_dim, depth, num_heads, encoder_embed_dim):\n        super().__init__()\n        self.num_patches = num_patches\n        self.patch_size = patch_size\n        self.in_chans = in_chans\n        self.decoder_embed = nn.Linear(encoder_embed_dim, embed_dim)\n        self.mask_token = nn.Parameter(torch.zeros(1, 1, e